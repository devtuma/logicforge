// Schema do banco de dados LogicForge
// Modelos para usuários, projetos e saídas de lógica booleana

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  image     String?
  projects  Project[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String          @id @default(cuid())
  name        String
  description String?
  variables   Json            // [{name: "A", description: "Sensor 1"}]
  ordering    String          @default("binary") // "binary" | "gray"
  outputs     ProjectOutput[]
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId])
}

model ProjectOutput {
  id        String  @id @default(cuid())
  name      String
  values    Json    // [0, 1, 1, 0, "X", 1, ...]
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
